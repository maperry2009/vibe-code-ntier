@page
@model IndexModel
@{
    ViewData["Title"] = "Staffing Database";
}

<section class="hero text-center">
    <p class="tier-flow">
        <span class="tier-badge">Web</span>
        <span class="tier-arrow" aria-hidden="true">→</span>
        <span class="tier-badge">API</span>
        <span class="tier-arrow" aria-hidden="true">→</span>
        <span class="tier-badge">PostgreSQL</span>
    </p>
    <h1 class="hero-title">Staffing Database</h1>
    <p class="hero-subtitle">
        Enter your name below. It travels through the web app, REST API, and into the database.
    </p>
</section>

<div class="demo-grid">
    <div class="demo-card">
        <div class="card-label">Your input</div>
        <form method="post" class="name-form">
            <label asp-for="Name" class="form-label">First name</label>
            <input asp-for="Name" class="form-control name-input" placeholder="e.g. Michael" autofocus />

            <label asp-for="LastName" class="form-label">Last name</label>
            <div class="input-row">
                <input asp-for="LastName" class="form-control name-input" placeholder="e.g. Perry" />
                <button type="submit" class="btn btn-submit">Save name</button>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="alert alert-error" role="alert">@Model.ErrorMessage</div>
            }
        </form>
    </div>

    <div class="demo-card">
        <div class="card-header-row">
            <div class="card-label">Saved names</div>
            <span class="name-count">@Model.Names.Count</span>
        </div>

        @if (Model.Names.Count == 0)
        {
            <div class="empty-state">
                <p>No names yet</p>
                <span>Submit a name to see it stored via the API.</span>
            </div>
        }
        else
        {
            <ul class="name-list">
                @foreach (var guest in Model.Names)
                {
                    var displayName = $"{guest.Name} {guest.LastName}".Trim();
                    var initial = string.IsNullOrWhiteSpace(guest.Name)
                        ? "?"
                        : char.ToUpper(guest.Name.Trim()[0]).ToString();
                    <li class="name-item">
                        <span class="avatar" aria-hidden="true">@initial</span>
                        <div class="name-details">
                            <strong>@displayName</strong>
                            <span>@guest.CreatedAt.ToLocalTime().ToString("MMM d, yyyy · h:mm tt")</span>
                        </div>
                    </li>
                }
            </ul>
        }
    </div>
</div>
